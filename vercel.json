{
  "buildCommand": "npm run build && cp -r design-review dist/design-review",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": false,
  "trailingSlash": false,
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "github": {
    "enabled": true,
    "autoAlias": true,
    "autoJobCancelation": true
  },
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/workbox-(.+)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "rewrites": [
    { "source": "/design-review/(.*)", "destination": "/design-review/$1" },
    { "source": "/geometric-explorer", "destination": "/design-review/islamic-patterns/generate.html" },
    { "source": "/api/og/:id", "destination": "/api/og/[id]" },
    { "source": "/tts-lab", "destination": "https://poetry-bil-araby-2mb0.onrender.com/tts-lab" },
    { "source": "/((?!design-review|api/).*)", "destination": "/index.html" }
  ]
}
