# Frontend Configuration (VITE_ prefix required)
# Get your Gemini API key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your-api-key-here

# Backend API URL (optional, defaults to http://localhost:3001)
VITE_API_URL=http://localhost:3001

# Supabase Configuration (optional, for authentication features)
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend Configuration (for server.js)
# PostgreSQL Connection (use DATABASE_URL for production, or individual vars for local)
# DATABASE_URL=postgresql://user:password@host:5432/database  # Production (Supabase/Render)
# PGUSER=your_username          # Local development (defaults to $USER)
# PGHOST=localhost              # Local development (defaults to localhost)
# PGDATABASE=qafiyah           # Local development (defaults to qafiyah)
# PGPASSWORD=your_password      # Local development (defaults to empty)
# PGPORT=5432                   # Local development (defaults to 5432)

# Backend Server Configuration
PORT=3001                       # API server port (defaults to 3001)

# Logging Configuration
LOG_ENABLED=true                # Enable HTTP request logging (default: true)
LOG_DEBUG=false                 # Enable verbose database debug logs (default: false)
